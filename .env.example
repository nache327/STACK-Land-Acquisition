# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zoning

# === Anthropic / Claude ===
# Required for ordinance parsing (Phase 3+)
ANTHROPIC_API_KEY=

# === Optional data sources ===
# Regrid API — nationwide parcel fallback when ArcGIS discovery fails
REGRID_API_KEY=

# === Public GIS services (defaults work; override only if endpoints change) ===
FEMA_NFHL_URL=https://hazards.fema.gov/arcgis/rest/services/public/NFHL/MapServer
USFWS_NWI_URL=https://www.fws.gov/wetlandsmapservice/services/Wetlands/MapServer
USGS_3DEP_DEM_URL=https://elevation.nationalmap.gov/arcgis/rest/services/3DEPElevation/ImageServer

# === Frontend (Next.js public vars) ===
NEXT_PUBLIC_MAPLIBRE_STYLE=https://tiles.openfreemap.org/styles/liberty
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_TILESERV_URL=http://localhost:7800

# === CORS (comma-separated origins, defaults to localhost dev) ===
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
