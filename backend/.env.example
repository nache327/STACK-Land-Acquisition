# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zoning
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Regrid fallback (paid) ────────────────────────────────────────
# Set this to enable parcel lookup for cities with no public ArcGIS GIS.
# Sign up at https://regrid.com/developers
REGRID_API_KEY=

# ── Optional: CORS origins (comma-separated) ────────────────────────────────
# Add your Vercel frontend URL for production:
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Public GIS services (leave blank to use defaults) ───────────────────────
FEMA_NFHL_URL=
USFWS_NWI_URL=
USGS_3DEP_DEM_URL=

# ── Optional: Mapbox isochrones (server-side ring-metric precompute) ────────
# Get a token at https://account.mapbox.com/access-tokens/. Isochrone API is
# included in the default scopes. The frontend has its own NEXT_PUBLIC_*
# token; this one is server-side only and can be a secret.
MAPBOX_TOKEN=
# Sliding-window rate cap. Mapbox free tier is 300 rpm; bump for paid plans.
MAPBOX_ISOCHRONE_RPM=300
