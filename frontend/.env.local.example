# Site Scout — required environment variables
# Copy this file to .env.local and fill in the values.
# For Vercel, add these in the project's Environment Variables settings.

# Backend FastAPI URL (Railway)
NEXT_PUBLIC_API_URL=https://your-railway-backend.up.railway.app

# Anthropic API key — used by backend for Layer 3 ordinance parsing
# This goes in the BACKEND environment, not here.
# ANTHROPIC_API_KEY=  ← set on Railway, not Vercel
