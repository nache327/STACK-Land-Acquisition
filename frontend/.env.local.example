# Site Scout — required environment variables
# Copy this file to .env.local and fill in the values.
# For Vercel, add these in the project's Environment Variables settings.

# Backend FastAPI URL (Railway)
NEXT_PUBLIC_API_URL=https://your-railway-backend.up.railway.app

# Anthropic API key — used by:
#   1. The Zoning Verifier Chat Panel (/api/zoning-chat) — set this on Vercel
#   2. Backend ordinance parser — also set on Railway
ANTHROPIC_API_KEY=sk-ant-...
